<Window x:Class="PortChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PortChecker.Converters"
        Title="Port Checker"
        Width="1280"
        Height="780"
        MinWidth="1080"
        MinHeight="680"
        Background="#F5F7FB"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" Invert="True" />

        <SolidColorBrush x:Key="InkBrush" Color="#182230" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="LineBrush" Color="#E4E7EC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#EEF2F8" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="RowHeight" Value="38" />
            <Setter Property="ColumnHeaderHeight" Value="38" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#FAFBFD" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Port Checker" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="本机 TCP/UDP 端口占用、进程和 svchost 服务明细"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource MutedBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#EAF1FF" CornerRadius="6" Padding="10,6" Margin="0,0,8,0" ToolTip="{Binding PermissionNotice}">
                    <TextBlock Text="{Binding ElevationText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                </Border>
                <Button Content="打开任务管理器" Command="{Binding OpenTaskManagerCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="全部端口" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding TotalCount}" FontSize="26" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="TCP" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding TcpCount}" FontSize="26" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="UDP" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding UdpCount}" FontSize="26" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="svchost 端口" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="{Binding SvchostCount}" FontSize="26" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="18,18,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     MinWidth="260" />
                            <TextBlock Text="搜索端口、PID、进程、服务或路径"
                                       Foreground="#98A2B3"
                                       Margin="13,0,42,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding SearchText, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                            <Button Content="X"
                                    Width="28"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,4,0"
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}" />
                        </Grid>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ProtocolFilters}"
                                  SelectedItem="{Binding ProtocolFilter}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="10,0,0,0" />

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding StateFilters}"
                                  SelectedItem="{Binding StateFilter}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="10,0,0,0" />

                        <TextBlock Grid.Column="3"
                                   Text="{Binding FilteredCount, StringFormat=显示 {0} 条}"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0" />
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PortsView}"
                              SelectedItem="{Binding SelectedPort, Mode=TwoWay}"
                              Margin="1,0,1,1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="协议" Binding="{Binding ProtocolText}" Width="72" />
                            <DataGridTextColumn Header="本地地址" Binding="{Binding LocalEndpoint}" Width="170" />
                            <DataGridTextColumn Header="远程地址" Binding="{Binding RemoteEndpoint}" Width="170" />
                            <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="120" />
                            <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" />
                            <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="130" />
                            <DataGridTextColumn Header="服务" Binding="{Binding ServiceSummary}" Width="*" MinWidth="180" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="18,18,18,14">
                        <TextBlock Text="进程详情" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedPort.ProcessName}" FontSize="24" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding SelectedPort.ProcessId, StringFormat=PID {0}}"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,0,18,12">
                        <StackPanel>
                            <TextBlock Text="端点" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding SelectedPort.LocalEndpoint}" FontWeight="SemiBold" Margin="0,4,0,12" />

                            <TextBlock Text="远程" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding SelectedPort.RemoteEndpoint}" FontWeight="SemiBold" Margin="0,4,0,12" />

                            <TextBlock Text="用户" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding SelectedPort.UserName, TargetNullValue=无用户信息}" FontWeight="SemiBold" Margin="0,4,0,12" />

                            <TextBlock Text="路径" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding SelectedPort.PathSummary}"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,12" />

                            <TextBlock Text="命令行" Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding SelectedPort.CommandSummary}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,16" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="svchost 服务" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedServicesCount}"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedPort.Services}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,0,8"
                                                Background="#FAFBFD">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,6" />
                                                <UniformGrid Columns="2">
                                                    <TextBlock Text="{Binding State, StringFormat=状态：{0}}" Foreground="{StaticResource MutedBrush}" />
                                                    <TextBlock Text="{Binding StartMode, StringFormat=启动：{0}}" Foreground="{StaticResource MutedBrush}" />
                                                </UniformGrid>
                                                <TextBlock Text="{Binding PathName}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,10,0,0">
                                                    <Button Content="停止服务"
                                                            Command="{Binding DataContext.StopServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource DangerButton}"
                                                            Margin="0,0,8,0" />
                                                    <Button Content="重启服务"
                                                            Command="{Binding DataContext.RestartServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SecondaryButton}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="18">
                        <TextBlock Text="{Binding KillProcessWarningText}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"
                                   Visibility="{Binding KillProcessWarningText, Converter={StaticResource StringToVisibilityConverter}}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="定位文件" Command="{Binding OpenLocationCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                            <Button Content="结束进程"
                                    Command="{Binding KillProcessCommand}"
                                    Style="{StaticResource DangerButton}"
                                    Visibility="{Binding CanKillSelectedProcess, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Content="按服务操作"
                                    Style="{StaticResource SecondaryButton}"
                                    IsEnabled="False"
                                    Visibility="{Binding KillProcessWarningText, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
            <TextBlock Grid.Column="1" Text="{Binding LastScannedText}" Foreground="{StaticResource MutedBrush}" />
        </Grid>
    </Grid>
</Window>
