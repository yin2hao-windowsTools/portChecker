<Window x:Class="PortChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PortChecker.Converters"
        Title="Port Checker"
        Width="1600"
        Height="860"
        MinWidth="1360"
        MinHeight="760"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="13"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" Invert="True" />

        <SolidColorBrush x:Key="InkBrush" Color="#111827" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#98A2B3" />
        <SolidColorBrush x:Key="LineBrush" Color="#DCE5F2" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F6F8FC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="ControlBrush" Color="#FDFEFF" />
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#F3F7FD" />
        <SolidColorBrush x:Key="ControlPressedBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="ControlDisabledBrush" Color="#EEF2F7" />
        <SolidColorBrush x:Key="ControlDisabledTextBrush" Color="#98A2B3" />
        <SolidColorBrush x:Key="CardPanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#DCE5F2" />
        <SolidColorBrush x:Key="ContentHoverBrush" Color="#F2F7FF" />
        <SolidColorBrush x:Key="ContentSelectedBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="ContentSelectedForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#F3F7FD" />
        <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#F6F9FD" />
        <SolidColorBrush x:Key="DataGridHeaderTextBrush" Color="#667085" />
        <SolidColorBrush x:Key="DataGridAltRowBrush" Color="#FBFCFE" />
        <SolidColorBrush x:Key="RowBorderBrush" Color="#EEF2F7" />
        <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#EEF2F7" />
        <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="PermissionPanelBrush" Color="#F8FBFF" />
        <SolidColorBrush x:Key="PermissionBorderBrush" Color="#CFE0FF" />
        <SolidColorBrush x:Key="BadgeBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="BadgeTextBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="EmptyPanelBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="EmptyStatePanelBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="EmptyStateBorderBrush" Color="#CFE0FF" />
        <SolidColorBrush x:Key="EmptyStateTextBrush" Color="#334155" />
        <SolidColorBrush x:Key="PlaceholderBrush" Color="#8D98AA" />
        <SolidColorBrush x:Key="WarningBorderBrush" Color="#FED7AA" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#9A3412" />
        <SolidColorBrush x:Key="InfoPanelBrush" Color="#EEF6FF" />
        <SolidColorBrush x:Key="InfoBorderBrush" Color="#BFDBFE" />
        <SolidColorBrush x:Key="InfoTextBrush" Color="#1E40AF" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="HoverBrush" Color="#F2F7FF" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="NavigationPanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NavigationItemBrush" Color="#FDFEFF" />
        <SolidColorBrush x:Key="NavigationItemHoverBrush" Color="#F3F7FD" />
        <SolidColorBrush x:Key="NavigationItemSelectedBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="NavigationItemBorderBrush" Color="#DCE5F2" />
        <SolidColorBrush x:Key="NavigationItemSelectedBorderBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="NavigationItemForegroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="NavigationItemSubtextBrush" Color="#667085" />
        <SolidColorBrush x:Key="NavigationItemSelectedForegroundBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="NavigationItemSelectedSubtextBrush" Color="#334155" />
        <SolidColorBrush x:Key="NavigationSelectionIndicatorBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PopupPanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PopupBorderBrush" Color="#CBD8EA" />
        <SolidColorBrush x:Key="PopupHoverBrush" Color="#F3F7FD" />
        <SolidColorBrush x:Key="PopupPressedBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EEF5FF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#3FB773" />
        <SolidColorBrush x:Key="SuccessSoftBrush" Color="#EAF8F1" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F97316" />
        <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFF2E8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />

        <LinearGradientBrush x:Key="AppIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1D6EF2" Offset="0" />
            <GradientStop Color="#3B82F6" Offset="0.55" />
            <GradientStop Color="#175CE6" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BlueIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4F8DFF" Offset="0" />
            <GradientStop Color="#2368E8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SkyIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#60A5FA" Offset="0" />
            <GradientStop Color="#2586E8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GreenIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#76D391" Offset="0" />
            <GradientStop Color="#3AA96F" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="OrangeIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF9F43" Offset="0" />
            <GradientStop Color="#F36A13" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#18233A" BlurRadius="22" ShadowDepth="2" Opacity="0.07" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentDarkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderPopupToggleButton" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PopupHoverBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PopupPressedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderPopupMenuItemButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PopupHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PopupPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource ControlDisabledTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderMenu" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <ControlTemplate x:Key="MenuItemTemplate" TargetType="MenuItem">
            <Grid>
                <Border x:Name="ItemBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                    <ContentPresenter ContentSource="Header"
                                      RecognizesAccessKey="True"
                                      VerticalAlignment="Center" />
                </Border>

                <Popup x:Name="PART_Popup"
                       AllowsTransparency="True"
                       Focusable="False"
                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       Placement="Bottom"
                       PopupAnimation="Fade">
                    <Border Background="{DynamicResource PopupPanelBrush}"
                            BorderBrush="{DynamicResource PopupBorderBrush}"
                            BorderThickness="1"
                            MinWidth="156"
                            Padding="3"
                            SnapsToDevicePixels="True">
                        <ScrollViewer CanContentScroll="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter TargetName="ItemBorder" Property="CornerRadius" Value="6" />
                </Trigger>
                <Trigger Property="Role" Value="TopLevelItem">
                    <Setter TargetName="ItemBorder" Property="CornerRadius" Value="6" />
                </Trigger>
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PopupHoverBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PopupPressedBrush}" />
                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource ControlDisabledTextBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="HeaderMenuItem" TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template" Value="{StaticResource MenuItemTemplate}" />
        </Style>

        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FDFEFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#111827" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#111827" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InfoBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InfoTextBrushKey}" Color="#111827" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#111827" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#EAF2FF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#EAF2FF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111827" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#EAF2FF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#111827" />
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#98A2B3" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#DCE5F2" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FFFFFF" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#98A2B3" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#667085" />

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource ControlDisabledTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlPressedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource ControlDisabledBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource ControlDisabledTextBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template" Value="{StaticResource MenuItemTemplate}" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Margin="8,4"
                                Background="{DynamicResource LineBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{DynamicResource ScrollBarThumbBrush}"
                                CornerRadius="4"
                                Margin="{TemplateBinding Margin}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollBarThumbHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{DynamicResource ScrollBarTrackBrush}"
                  MinWidth="12"
                  SnapsToDevicePixels="True">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                      Style="{StaticResource ScrollBarPageButton}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Margin="3,2"
                               Style="{StaticResource ScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                      Style="{StaticResource ScrollBarPageButton}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Background="{DynamicResource ScrollBarTrackBrush}"
                  MinHeight="12"
                  SnapsToDevicePixels="True">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                      Style="{StaticResource ScrollBarPageButton}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Margin="2,3"
                               Style="{StaticResource ScrollBarThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                      Style="{StaticResource ScrollBarPageButton}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollBarTrackBrush}" />
            <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
            <Setter Property="Width" Value="12" />
            <Setter Property="MinWidth" Value="12" />
            <Setter Property="MinHeight" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="12" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="Padding" Value="38,7,38,7" />
        </Style>

        <Style x:Key="CompactTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MaxDropDownHeight" Value="260" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource ComboBoxToggleButton}">
                                <Grid>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      IsHitTestVisible="False"
                                                      Margin="{TemplateBinding Padding}"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{TemplateBinding Foreground}"
                                             Focusable="True"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"
                                             Margin="{TemplateBinding Padding}"
                                             Visibility="Hidden" />
                                    <Path x:Name="Arrow"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="{DynamicResource MutedBrush}"
                                          HorizontalAlignment="Right"
                                          Margin="0,0,12,0"
                                          VerticalAlignment="Center" />
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{DynamicResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Padding="2"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer Background="{DynamicResource PanelBrush}"
                                                  CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ControlDisabledTextBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource ControlDisabledTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

