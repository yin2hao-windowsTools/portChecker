<Window x:Class="PortChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PortChecker.Converters"
        Title="Port Checker"
        Width="1420"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="13"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" Invert="True" />

        <SolidColorBrush x:Key="InkBrush" Color="#111827" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#98A2B3" />
        <SolidColorBrush x:Key="LineBrush" Color="#DCE5F2" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F6F8FC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="ControlBrush" Color="#FDFEFF" />
        <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#F3F7FD" />
        <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#F6F9FD" />
        <SolidColorBrush x:Key="DataGridAltRowBrush" Color="#FBFCFE" />
        <SolidColorBrush x:Key="RowBorderBrush" Color="#EEF2F7" />
        <SolidColorBrush x:Key="PermissionPanelBrush" Color="#F8FBFF" />
        <SolidColorBrush x:Key="PermissionBorderBrush" Color="#CFE0FF" />
        <SolidColorBrush x:Key="BadgeBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="EmptyPanelBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="PlaceholderBrush" Color="#8D98AA" />
        <SolidColorBrush x:Key="WarningBorderBrush" Color="#FED7AA" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#9A3412" />
        <SolidColorBrush x:Key="InfoPanelBrush" Color="#EEF6FF" />
        <SolidColorBrush x:Key="InfoBorderBrush" Color="#BFDBFE" />
        <SolidColorBrush x:Key="InfoTextBrush" Color="#1E40AF" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="HoverBrush" Color="#F2F7FF" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#EAF2FF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EEF5FF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#3FB773" />
        <SolidColorBrush x:Key="SuccessSoftBrush" Color="#EAF8F1" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F97316" />
        <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFF2E8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />

        <LinearGradientBrush x:Key="AppIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1D6EF2" Offset="0" />
            <GradientStop Color="#3B82F6" Offset="0.55" />
            <GradientStop Color="#175CE6" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BlueIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4F8DFF" Offset="0" />
            <GradientStop Color="#2368E8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SkyIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#60A5FA" Offset="0" />
            <GradientStop Color="#2586E8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GreenIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#76D391" Offset="0" />
            <GradientStop Color="#3AA96F" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="OrangeIconBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF9F43" Offset="0" />
            <GradientStop Color="#F36A13" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#18233A" BlurRadius="22" ShadowDepth="2" Opacity="0.07" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentDarkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryButtonHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderMenu" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="Padding" Value="38,7,38,7" />
        </Style>

        <Style x:Key="CompactTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="MetricLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="MetricValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="34" />
        </Style>

        <Style x:Key="PanelTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FieldLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="FieldValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="MonoTableText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="IconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="RowHeight" Value="40" />
            <Setter Property="ColumnHeaderHeight" Value="40" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource DataGridAltRowBrush}" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource DataGridHeaderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource RowBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28,24,28,16" ToolTip="{Binding StatusMessage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1.55*" />
            <RowDefinition Height="1.05*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="50"
                    Height="50"
                    CornerRadius="8"
                    Background="{StaticResource AppIconBrush}"
                    VerticalAlignment="Center">
                <TextBlock Text="&#xE8A5;"
                           Style="{StaticResource IconGlyph}"
                           Foreground="White"
                           FontSize="25" />
            </Border>

            <StackPanel Grid.Column="1" Margin="20,0,20,0" VerticalAlignment="Center">
                <TextBlock Text="Port Checker"
                           FontSize="29"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource InkBrush}" />
                <TextBlock Text="本机 TCP/UDP 端口占用、进程和 svchost 服务明细"
                           Margin="0,4,0,0"
                           FontSize="14"
                           Foreground="{DynamicResource MutedBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="{DynamicResource PermissionPanelBrush}"
                        BorderBrush="{DynamicResource PermissionBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,9"
                        Margin="0,0,10,0"
                        ToolTip="{Binding PermissionNotice}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE83D;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding ElevationText}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Button Command="{Binding ToggleThemeCommand}"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="{Binding ThemeToggleToolTip}"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE708;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding ThemeToggleText}" />
                    </StackPanel>
                </Button>

                <Menu Style="{StaticResource HeaderMenu}" Margin="0,0,10,0">
                    <MenuItem Header="更多" Style="{StaticResource HeaderMenuItem}">
                        <MenuItem Header="关于 Port Checker" Command="{Binding ShowAboutCommand}" />
                        <MenuItem Header="检查更新" Command="{Binding CheckForUpdatesCommand}" />
                        <Separator />
                        <MenuItem Header="开发者主页" Command="{Binding OpenDeveloperHomeCommand}" />
                        <MenuItem Header="项目仓库" Command="{Binding OpenRepositoryCommand}" />
                        <Separator />
                        <MenuItem Header="许可证" Command="{Binding ShowLicenseCommand}" />
                    </MenuItem>
                </Menu>

                <Button Command="{Binding OpenTaskManagerCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D9;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="打开任务管理器" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="White"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="刷新" Foreground="White" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource CardBorder}" Height="86" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="48"
                            Height="48"
                            CornerRadius="8"
                            Background="{StaticResource BlueIconBrush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xECA5;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="White"
                                   FontSize="24" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="全部端口" Style="{StaticResource MetricLabelText}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding TotalCount}" Style="{StaticResource MetricValueText}" />
                            <TextBlock Text="&#x2191;"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="17"
                                       Margin="8,8,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}" Height="86" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="48"
                            Height="48"
                            CornerRadius="8"
                            Background="{StaticResource SkyIconBrush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE9D9;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="White"
                                   FontSize="23" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="TCP 端口" Style="{StaticResource MetricLabelText}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding TcpCount}" Style="{StaticResource MetricValueText}" />
                            <TextBlock Text="&#x2191;"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="17"
                                       Margin="8,8,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}" Height="86" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="48"
                            Height="48"
                            CornerRadius="8"
                            Background="{StaticResource GreenIconBrush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE968;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="White"
                                   FontSize="23" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="UDP 端口" Style="{StaticResource MetricLabelText}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding UdpCount}" Style="{StaticResource MetricValueText}" />
                            <TextBlock Text="&#x2191;"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="17"
                                       Margin="8,8,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}" Height="86">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="48"
                            Height="48"
                            CornerRadius="8"
                            Background="{StaticResource OrangeIconBrush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE713;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="White"
                                   FontSize="23" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="svchost 端口" Style="{StaticResource MetricLabelText}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding SvchostCount}" Style="{StaticResource MetricValueText}" />
                            <TextBlock Text="&#x2191;"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="17"
                                       Margin="8,8,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.25*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="18,14,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SearchTextBoxStyle}"
                                     MinWidth="330" />
                            <TextBlock Text="&#xE721;"
                                       Style="{StaticResource IconGlyph}"
                                       Foreground="{DynamicResource MutedBrush}"
                                       HorizontalAlignment="Left"
                                       Margin="13,0,0,0"
                                       IsHitTestVisible="False" />
                            <TextBlock Text="搜索端口、PID、进程、服务或路径"
                                       Foreground="{DynamicResource PlaceholderBrush}"
                                       Margin="38,0,42,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding SearchText, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                            <Button Width="28"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,5,0"
                                    Padding="0"
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="&#xE711;"
                                           Style="{StaticResource IconGlyph}"
                                           FontSize="12"
                                           Foreground="{DynamicResource MutedBrush}" />
                            </Button>
                        </Grid>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ProtocolFilters}"
                                  SelectedItem="{Binding ProtocolFilter}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  MinWidth="126"
                                  Margin="10,0,0,0" />

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding StateFilters}"
                                  SelectedItem="{Binding StateFilter}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  MinWidth="136"
                                  Margin="10,0,0,0" />

                        <TextBlock Grid.Column="3"
                                   Text="{Binding FilteredCount, StringFormat=共 {0} 条}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="18,0,0,0" />

                        <TextBlock Grid.Column="4"
                                   Text="&#xE71C;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="16,0,2,0" />
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PortsView}"
                              SelectedItem="{Binding SelectedPort, Mode=TwoWay}"
                              Margin="1,0,1,1">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="协议" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BadgeBrush}"
                                                CornerRadius="4"
                                                Padding="7,3"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding ProtocolText}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="本地地址" Width="188">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LocalEndpoint}" Style="{StaticResource MonoTableText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="远程地址" Width="176">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RemoteEndpoint}" Style="{StaticResource MonoTableText}" Foreground="{DynamicResource MutedBrush}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="110" />
                            <DataGridTemplateColumn Header="PID" Width="78">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProcessId}" Style="{StaticResource MonoTableText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="138" />
                            <DataGridTextColumn Header="服务" Binding="{Binding ServiceSummary}" Width="*" MinWidth="170" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1"
                            Background="{DynamicResource EmptyPanelBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding EmptyPortListMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding EmptyPortListMessage}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="18,16,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="进程详情" Style="{StaticResource PanelTitleText}" />
                            <TextBlock Text="{Binding SelectedPort.ProcessName, TargetNullValue=未选择进程}"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Margin="0,12,0,0" />
                            <TextBlock Text="{Binding SelectedPort.ProcessId, StringFormat=PID {0}, TargetNullValue=PID --}"
                                       Foreground="{DynamicResource MutedBrush}"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{DynamicResource BadgeBrush}"
                                CornerRadius="4"
                                Padding="10,5"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding SelectedPort.ProtocolText, TargetNullValue=--}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,0,18,10">
                        <StackPanel>
                            <TextBlock Text="端点（本地地址）" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.LocalEndpoint, TargetNullValue=--}"
                                       Style="{StaticResource FieldValueText}"
                                       FontFamily="Cascadia Mono, Consolas" />

                            <TextBlock Text="远程地址" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.RemoteEndpoint, TargetNullValue=--}"
                                       Style="{StaticResource FieldValueText}"
                                       FontFamily="Cascadia Mono, Consolas" />

                            <TextBlock Text="服务" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.ServiceSummary, TargetNullValue=--}" Style="{StaticResource FieldValueText}" />

                            <TextBlock Text="用户" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.UserName, TargetNullValue=无用户信息}" Style="{StaticResource FieldValueText}" />

                            <TextBlock Text="路径" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.PathSummary, TargetNullValue=无路径或权限不足}"
                                       Style="{StaticResource FieldValueText}" />

                            <TextBlock Text="命令行" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.CommandSummary, TargetNullValue=无命令行或权限不足}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource InkBrush}"
                                       Margin="0,0,0,14" />

                            <Border Background="{DynamicResource WarningSoftBrush}"
                                    BorderBrush="{DynamicResource WarningBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    Visibility="{Binding KillProcessWarningText, Converter={StaticResource StringToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE946;"
                                               Style="{StaticResource IconGlyph}"
                                               Foreground="{DynamicResource WarningBrush}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ServiceOperationRiskText}"
                                               Foreground="{DynamicResource WarningTextBrush}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource InfoPanelBrush}"
                                    BorderBrush="{DynamicResource InfoBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    Visibility="{Binding ServiceOperationResult, Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="{Binding ServiceOperationResult}"
                                           Foreground="{DynamicResource InfoTextBrush}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Grid Margin="0,2,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="svchost 服务" Style="{StaticResource PanelTitleText}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedServicesCount, StringFormat={}{0} 个}"
                                           Foreground="{DynamicResource MutedBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedPort.Services}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,0,8"
                                                Background="{DynamicResource PanelAltBrush}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,6" />
                                                <UniformGrid Columns="2">
                                                    <TextBlock Text="{Binding State, StringFormat=服务状态：{0}}" Foreground="{DynamicResource MutedBrush}" />
                                                    <TextBlock Text="{Binding StartMode, StringFormat=启动：{0}}" Foreground="{DynamicResource MutedBrush}" />
                                                </UniformGrid>
                                                <TextBlock Text="{Binding PathName}" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,10,0,0">
                                                    <Button Content="停止服务"
                                                            Command="{Binding DataContext.StopServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource DangerButton}"
                                                            Margin="0,0,8,0" />
                                                    <Button Content="重启服务"
                                                            Command="{Binding DataContext.RestartServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SecondaryButton}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="18,10,18,14">
                        <TextBlock Text="{Binding KillProcessWarningText}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"
                                   Visibility="{Binding KillProcessWarningText, Converter={StaticResource StringToVisibilityConverter}}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Command="{Binding OpenLocationCommand}"
                                    Style="{StaticResource SecondaryButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;"
                                               Style="{StaticResource IconGlyph}"
                                               Foreground="{DynamicResource MutedBrush}"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="定位文件" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Command="{Binding KillProcessCommand}"
                                    Style="{StaticResource DangerButton}"
                                    Visibility="{Binding CanKillSelectedProcess, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;"
                                               Style="{StaticResource IconGlyph}"
                                               Foreground="White"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="结束进程" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryButton}"
                                    IsEnabled="False"
                                    Visibility="{Binding KillProcessWarningText, Converter={StaticResource StringToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;"
                                               Style="{StaticResource IconGlyph}"
                                               Foreground="{DynamicResource MutedBrush}"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="按服务操作" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="18,13,18,8">
                        <TextBlock Text="Windows 保留端口" Style="{StaticResource PanelTitleText}" />
                        <TextBlock Text="{Binding ReservedPortStatusMessage}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <DataGrid ItemsSource="{Binding ReservedPortRanges}"
                                  SelectedItem="{Binding SelectedReservedPortRange, Mode=TwoWay}"
                                  Margin="1,0,1,1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="协议" Binding="{Binding ProtocolText}" Width="80" />
                                <DataGridTextColumn Header="范围" Binding="{Binding RangeText}" Width="150" />
                                <DataGridTextColumn Header="端口数" Binding="{Binding PortCount}" Width="92" />
                                <DataGridTextColumn Header="存储" Binding="{Binding StoreText}" Width="96" />
                                <DataGridTextColumn Header="来源" Binding="{Binding SourceText}" Width="*" MinWidth="110" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="{DynamicResource EmptyPanelBrush}"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding EmptyReservedPortMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding EmptyReservedPortMessage}"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid Margin="18,13,18,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="添加保留范围"
                                   Style="{StaticResource PanelTitleText}"
                                   VerticalAlignment="Center" />

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ReservedPortListStores}"
                                  SelectedItem="{Binding ReservedPortListStore}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  MinWidth="110"
                                  Margin="10,0,0,0" />

                        <TextBlock Grid.Column="2"
                                   Text="{Binding ReservedPortRangeCount, StringFormat=共 {0} 条}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0" />

                        <Button Grid.Column="3"
                                Command="{Binding RefreshReservedPortsCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="12,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;"
                                           Style="{StaticResource IconGlyph}"
                                           Foreground="{DynamicResource MutedBrush}"
                                           Margin="0,0,7,0" />
                                <TextBlock Text="刷新保留端口" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,12,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="协议" Style="{StaticResource FieldLabelText}" />
                        <ComboBox Grid.Row="1"
                                  ItemsSource="{Binding ReservedPortProtocols}"
                                  SelectedItem="{Binding ReservedPortProtocol}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  MinWidth="0" />

                        <TextBlock Grid.Column="2" Text="存储" Style="{StaticResource FieldLabelText}" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="2"
                                  ItemsSource="{Binding ReservedPortListStores}"
                                  SelectedItem="{Binding ReservedPortStore}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  MinWidth="0" />

                        <TextBlock Grid.Row="2" Text="起始端口" Style="{StaticResource FieldLabelText}" Margin="0,12,0,5" />
                        <Grid Grid.Row="3">
                            <TextBox Text="{Binding ReservedPortStart, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactTextBoxStyle}" />
                            <TextBlock Text="例如 5000"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding ReservedPortStart, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                        </Grid>

                        <TextBlock Grid.Row="2" Grid.Column="2" Text="端口数量" Style="{StaticResource FieldLabelText}" Margin="0,12,0,5" />
                        <Grid Grid.Row="3" Grid.Column="2">
                            <TextBox Text="{Binding ReservedPortCount, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactTextBoxStyle}" />
                            <TextBlock Text="例如 50"
                                       Foreground="{DynamicResource SubtleBrush}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding ReservedPortCount, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SelectedReservedPortRangeSummary}"
                                   Foreground="{DynamicResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding AdministeredReservedPortRangeCount, StringFormat=用户保留 {0} 条}"
                                   Foreground="{DynamicResource MutedBrush}" />
                    </StackPanel>

                    <Grid Grid.Row="3" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="164" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="164" />
                        </Grid.ColumnDefinitions>

                        <Button Command="{Binding AddReservedPortRangeCommand}"
                                Style="{StaticResource PrimaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;"
                                           Style="{StaticResource IconGlyph}"
                                           Foreground="White"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="添加范围" Foreground="White" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding DeleteReservedPortRangeCommand}"
                                Style="{StaticResource SecondaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;"
                                           Style="{StaticResource IconGlyph}"
                                           Foreground="{DynamicResource MutedBrush}"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="删除选中" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="4" Margin="0,13,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE73E;"
                           Style="{StaticResource IconGlyph}"
                           Foreground="{DynamicResource SuccessBrush}"
                           Margin="0,0,7,0" />
                <TextBlock Text="{Binding ScanStateText}" Style="{StaticResource StatusText}" FontWeight="SemiBold" />
                <Border Width="1" Background="{DynamicResource LineBrush}" Margin="16,2" />
                <TextBlock Text="{Binding PortCountStatusText}" Style="{StaticResource StatusText}" />
                <Border Width="1" Background="{DynamicResource LineBrush}" Margin="16,2" />
                <TextBlock Text="{Binding ScanTotalDurationText}" Style="{StaticResource StatusText}" />
                <Border Width="1" Background="{DynamicResource LineBrush}" Margin="16,2" />
                <TextBlock Text="{Binding ScanPortDurationText}" Style="{StaticResource StatusText}" />
                <Border Width="1" Background="{DynamicResource LineBrush}" Margin="16,2" />
                <TextBlock Text="{Binding ScanMetadataDurationText}" Style="{StaticResource StatusText}" />
                <Border Width="1" Background="{DynamicResource LineBrush}" Margin="16,2" />
                <TextBlock Text="{Binding ScanProcessCountText}" Style="{StaticResource StatusText}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="{Binding ElevationText}"
                           Style="{StaticResource StatusText}"
                           Margin="0,0,18,0" />
                <TextBlock Text="{Binding LastScannedText}" Style="{StaticResource StatusText}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
