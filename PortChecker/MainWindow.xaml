<Window x:Class="PortChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PortChecker.Converters"
        Title="Port Checker"
        Width="1280"
        Height="860"
        MinWidth="1080"
        MinHeight="760"
        Background="#F5F7FB"
        FontFamily="Segoe UI"
        FontSize="13"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" Invert="True" />

        <SolidColorBrush x:Key="InkBrush" Color="#111827" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="LineBrush" Color="#D9E2EF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="HoverBrush" Color="#F1F7FF" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#E8F1FF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF1FF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#059669" />
        <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#101828" BlurRadius="14" ShadowDepth="1" Opacity="0.06" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#F3F6FB" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderMenu" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="HeaderMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FDFEFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FDFEFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="MetricLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="PanelTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FieldLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="FieldValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="MonoTableText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="RowHeight" Value="40" />
            <Setter Property="ColumnHeaderHeight" Value="40" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#FBFCFE" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F6F9FD" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#EEF2F7" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2.1*" />
            <RowDefinition Height="1.8*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Port Checker" FontSize="30" FontWeight="SemiBold" />
                <TextBlock Text="本机 TCP/UDP 端口占用、进程和 svchost 服务明细"
                           Margin="0,5,0,0"
                           Foreground="{StaticResource MutedBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="#C7D7FE"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        Margin="0,0,8,0"
                        ToolTip="{Binding PermissionNotice}">
                    <TextBlock Text="{Binding ElevationText}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                </Border>
                <Menu Style="{StaticResource HeaderMenu}" Margin="0,0,8,0" VerticalAlignment="Center">
                    <MenuItem Header="关于" Style="{StaticResource HeaderMenuItem}">
                        <MenuItem Header="关于 Port Checker" Command="{Binding ShowAboutCommand}" />
                        <MenuItem Header="检查更新" Command="{Binding CheckForUpdatesCommand}" />
                        <Separator />
                        <MenuItem Header="开发者主页" Command="{Binding OpenDeveloperHomeCommand}" />
                        <MenuItem Header="项目仓库" Command="{Binding OpenRepositoryCommand}" />
                        <Separator />
                        <MenuItem Header="许可证" Command="{Binding ShowLicenseCommand}" />
                    </MenuItem>
                </Menu>
                <Button Content="打开任务管理器" Command="{Binding OpenTaskManagerCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="2" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="全部端口" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding TotalCount}" Style="{StaticResource MetricValueText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="#0EA5E9" CornerRadius="2" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TCP" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding TcpCount}" Style="{StaticResource MetricValueText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource SuccessBrush}" CornerRadius="2" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="UDP" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding UdpCount}" Style="{StaticResource MetricValueText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource WarningBrush}" CornerRadius="2" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="svchost 端口" Style="{StaticResource MetricLabelText}" />
                        <TextBlock Text="{Binding SvchostCount}" Style="{StaticResource MetricValueText}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="18,16,18,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource TextBoxStyle}"
                                     MinWidth="260" />
                            <TextBlock Text="搜索端口、PID、进程、服务或路径"
                                       Foreground="#98A2B3"
                                       Margin="13,0,42,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding SearchText, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                            <Button Content="X"
                                    Width="28"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,4,0"
                                    Padding="0"
                                    Command="{Binding ClearSearchCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}" />
                        </Grid>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ProtocolFilters}"
                                  SelectedItem="{Binding ProtocolFilter}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="10,0,0,0" />

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding StateFilters}"
                                  SelectedItem="{Binding StateFilter}"
                                  Style="{StaticResource ComboBoxStyle}"
                                  Margin="10,0,0,0" />

                        <TextBlock Grid.Column="3"
                                   Text="{Binding FilteredCount, StringFormat=显示 {0} 条}"
                                   Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0" />
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PortsView}"
                              SelectedItem="{Binding SelectedPort, Mode=TwoWay}"
                              Margin="1,0,1,1">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="协议" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#EEF6FF" CornerRadius="4" Padding="7,3" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding ProtocolText}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="本地地址" Width="176">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LocalEndpoint}" Style="{StaticResource MonoTableText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="远程地址" Width="176">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RemoteEndpoint}" Style="{StaticResource MonoTableText}" Foreground="{StaticResource MutedBrush}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="120" />
                            <DataGridTemplateColumn Header="PID" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProcessId}" Style="{StaticResource MonoTableText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="130" />
                            <DataGridTextColumn Header="服务" Binding="{Binding ServiceSummary}" Width="*" MinWidth="180" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1"
                            Background="#F8FAFD"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding EmptyPortListMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding EmptyPortListMessage}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="18,16,18,14">
                        <TextBlock Text="进程详情" Style="{StaticResource PanelTitleText}" />
                        <TextBlock Text="{Binding SelectedPort.ProcessName}" FontSize="24" FontWeight="SemiBold" Margin="0,9,0,0" />
                        <TextBlock Text="{Binding SelectedPort.ProcessId, StringFormat=PID {0}}"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,0,18,12">
                        <StackPanel>
                            <TextBlock Text="端点" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.LocalEndpoint}" Style="{StaticResource FieldValueText}" FontFamily="Cascadia Mono, Consolas" />

                            <TextBlock Text="远程" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.RemoteEndpoint}" Style="{StaticResource FieldValueText}" FontFamily="Cascadia Mono, Consolas" />

                            <TextBlock Text="用户" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.UserName, TargetNullValue=无用户信息}" Style="{StaticResource FieldValueText}" />

                            <TextBlock Text="路径" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.PathSummary}"
                                       Style="{StaticResource FieldValueText}" />

                            <TextBlock Text="命令行" Style="{StaticResource FieldLabelText}" />
                            <TextBlock Text="{Binding SelectedPort.CommandSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,0,0,16" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="svchost 服务" Style="{StaticResource PanelTitleText}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedServicesCount}"
                                           Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Background="#FFF8ED"
                                    BorderBrush="#FED7AA"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding KillProcessWarningText, Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="{Binding ServiceOperationRiskText}"
                                           Foreground="#9A3412"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Border Background="#EEF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding ServiceOperationResult, Converter={StaticResource StringToVisibilityConverter}}">
                                <TextBlock Text="{Binding ServiceOperationResult}"
                                           Foreground="#1E40AF"
                                           TextWrapping="Wrap" />
                            </Border>

                            <ItemsControl ItemsSource="{Binding SelectedPort.Services}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,0,8"
                                                Background="{StaticResource PanelAltBrush}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,6" />
                                                <UniformGrid Columns="2">
                                                    <TextBlock Text="{Binding State, StringFormat=服务状态：{0}}" Foreground="{StaticResource MutedBrush}" />
                                                    <TextBlock Text="{Binding StartMode, StringFormat=启动：{0}}" Foreground="{StaticResource MutedBrush}" />
                                                </UniformGrid>
                                                <TextBlock Text="{Binding PathName}" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,10,0,0">
                                                    <Button Content="停止服务"
                                                            Command="{Binding DataContext.StopServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource DangerButton}"
                                                            Margin="0,0,8,0" />
                                                    <Button Content="重启服务"
                                                            Command="{Binding DataContext.RestartServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SecondaryButton}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="18">
                        <TextBlock Text="{Binding KillProcessWarningText}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"
                                   Visibility="{Binding KillProcessWarningText, Converter={StaticResource StringToVisibilityConverter}}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="定位文件" Command="{Binding OpenLocationCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                            <Button Content="结束进程"
                                    Command="{Binding KillProcessCommand}"
                                    Style="{StaticResource DangerButton}"
                                    Visibility="{Binding CanKillSelectedProcess, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Content="按服务操作"
                                    Style="{StaticResource SecondaryButton}"
                                    IsEnabled="False"
                                    Visibility="{Binding KillProcessWarningText, Converter={StaticResource StringToVisibilityConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0" Margin="0,16,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.ColumnSpan="3" Margin="18,14,18,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Windows 保留端口" Style="{StaticResource PanelTitleText}" />
                        <TextBlock Text="{Binding ReservedPortStatusMessage}"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ReservedPortListStores}"
                              SelectedItem="{Binding ReservedPortListStore}"
                              Style="{StaticResource ComboBoxStyle}"
                              MinWidth="112"
                              Margin="10,0,0,0" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding ReservedPortRangeCount, StringFormat=共 {0} 条}"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0" />

                    <Button Grid.Column="3"
                            Content="刷新保留端口"
                            Command="{Binding RefreshReservedPortsCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,0,0" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <DataGrid ItemsSource="{Binding ReservedPortRanges}"
                                  SelectedItem="{Binding SelectedReservedPortRange, Mode=TwoWay}"
                                  Margin="1,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="协议" Binding="{Binding ProtocolText}" Width="80" />
                                <DataGridTextColumn Header="范围" Binding="{Binding RangeText}" Width="140" />
                                <DataGridTextColumn Header="端口数" Binding="{Binding PortCount}" Width="90" />
                                <DataGridTextColumn Header="存储" Binding="{Binding StoreText}" Width="90" />
                                <DataGridTextColumn Header="来源" Binding="{Binding SourceText}" Width="*" MinWidth="120" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="#F8FAFD"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding EmptyReservedPortMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding EmptyReservedPortMessage}"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>

                    <Border Grid.Column="2"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1,0,0,0"
                            Padding="18,0,18,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="添加保留范围" Style="{StaticResource PanelTitleText}" />

                            <Grid Grid.Row="1" Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="协议" Style="{StaticResource FieldLabelText}" />
                                <ComboBox Grid.Row="1"
                                          ItemsSource="{Binding ReservedPortProtocols}"
                                          SelectedItem="{Binding ReservedPortProtocol}"
                                          Style="{StaticResource ComboBoxStyle}"
                                          MinWidth="0" />

                                <TextBlock Grid.Column="2" Text="存储" Style="{StaticResource FieldLabelText}" />
                                <ComboBox Grid.Row="1"
                                          Grid.Column="2"
                                          ItemsSource="{Binding ReservedPortListStores}"
                                          SelectedItem="{Binding ReservedPortStore}"
                                          Style="{StaticResource ComboBoxStyle}"
                                          MinWidth="0" />

                                <TextBlock Grid.Row="2" Text="起始端口" Style="{StaticResource FieldLabelText}" Margin="0,10,0,4" />
                                <TextBox Grid.Row="3"
                                         Text="{Binding ReservedPortStart, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CompactTextBoxStyle}" />

                                <TextBlock Grid.Row="2" Grid.Column="2" Text="端口数量" Style="{StaticResource FieldLabelText}" Margin="0,10,0,4" />
                                <TextBox Grid.Row="3"
                                         Grid.Column="2"
                                         Text="{Binding ReservedPortCount, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CompactTextBoxStyle}" />
                            </Grid>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="{Binding SelectedReservedPortRangeSummary}"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="{Binding AdministeredReservedPortRangeCount, StringFormat=用户保留 {0} 条}"
                                           Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="添加"
                                        Command="{Binding AddReservedPortRangeCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,8,0" />
                                <Button Content="删除选中"
                                        Command="{Binding DeleteReservedPortRangeCommand}"
                                        Style="{StaticResource DangerButton}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
            <TextBlock Grid.Column="1" Text="{Binding LastScannedText}" Foreground="{StaticResource MutedBrush}" />
        </Grid>
    </Grid>
</Window>
